<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta http-equiv="Cache-control" content="no-cache, no-store, must-revalidate" />
  <title>Login | DC Infotech Exam Portal (v2)</title>
  <!-- Load local users file -->
  <script src="js/users.js"></script>
  <!-- Single login handling script -->
  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const form = document.querySelector(".login__form");
      if (!form) return;
      const email = document.getElementById("credential");
      const pwd = document.getElementById("password");

      // Inject small CSS (placeholder hide + float helper)
      const css = `
        .mat-mdc-input-element::placeholder{ color:#5f6368; opacity:1; transition:opacity .15s; }
        .mat-mdc-input-element:not(:placeholder-shown)::placeholder{ opacity:0; }
        .mat-form-field-should-float .mat-mdc-floating-label{ transform: translateY(-1.5em) scale(.75) !important; }
        .login-error{ color:#d93025; font-size:13px; margin-top:8px; }
      `;
      const style = document.createElement("style");
      style.textContent = css;
      document.head.appendChild(style);

      // Load users from js/users.js (with fallback)
      let users = [];
      if (window.USERS && Array.isArray(window.USERS)) {
        users = window.USERS;
        console.log("Loaded users from users.js:", users); // Debug log
      } else {
        users = [{ email: "test@example.com", password: "password123" }];
        console.warn(
          "Fallback to default user - users.js not loaded properly"
        );
      }

      function nearestField(el) {
        return (
          el &&
          (el.closest("mat-form-field") ||
            el.closest(".mat-mdc-form-field") ||
            el.parentElement)
        );
      }

      function updateInputState(input) {
        if (!input) return;
        const ff = nearestField(input);
        if (input.value && input.value.trim().length) {
          input.setAttribute("data-has-content", "1");
          if (ff) ff.classList.add("mat-form-field-should-float");
        } else {
          input.removeAttribute("data-has-content");
          if (ff) ff.classList.remove("mat-form-field-should-float");
        }
      }

      [email, pwd].forEach((inp) => {
        if (!inp) return;
        setTimeout(() => updateInputState(inp), 60);
        inp.addEventListener("input", () => updateInputState(inp));
        inp.addEventListener("focus", () => {
          const ff = nearestField(inp);
          if (ff) ff.classList.add("mat-focused");
        });
        inp.addEventListener("blur", () => {
          const ff = nearestField(inp);
          if (ff) ff.classList.remove("mat-focused");
          updateInputState(inp);
        });
      });

      function showError(msg) {
        let el = form.querySelector(".login-error");
        if (!el) {
          el = document.createElement("div");
          el.className = "login-error";
          form
            .querySelector(".login__form-actions")
            .insertAdjacentElement("afterend", el);
        }
        el.textContent = msg;
      }

      form.addEventListener("submit", function (ev) {
        ev.preventDefault();
        const loginButton = form.querySelector('button[type="submit"]');
        const originalButtonHTML = loginButton.innerHTML;

        // Show spinner and disable button
        loginButton.disabled = true;
        loginButton.innerHTML = `
     
          <style>

            @keyframes spin { to { transform: rotate(360deg); } }
            .spinner {
              display: inline-block;
              width: 20px;
              height: 20px;
              border: 3px solid rgba(255,255,255,0.3);
              border-radius: 50%;
              border-top-color: #fff;
              animation: spin 1s ease-in-out infinite;
            }
          </style>
          <span class="spinner"></span>
        `;

        const e = (email.value || "").trim().toLowerCase();
        const p = pwd.value || "";

        // Simulate network delay and then check credentials
        setTimeout(() => {
          if (!e || !p) {
            showError("Enter email and password");
            loginButton.disabled = false;
            loginButton.innerHTML = originalButtonHTML;
            return;
          }

          const match = users.find(
            (u) =>
              (u.email || "").toLowerCase() === e && (u.password || "") === p
          );
          if (match) {
            localStorage.setItem(
              "cm_user",
              JSON.stringify({ email: match.email, name: match.name })
            );
            window.location.href = "exam-portal/dashboard.html";
          } else {
            showError("Invalid email or password");
            loginButton.disabled = false;
            loginButton.innerHTML = originalButtonHTML;
          }
        }, 1000); // 1-second delay
      });
    }); // In your login form submit handler, update the localStorage line to:
    if (match) {
      // Store both email and name
      localStorage.setItem(
        "cm_user",
        JSON.stringify({
          email: match.email,
          name: match.name,
        })
      );

      // Redirect to dashboard
      window.location.href = "exam-portal/dashboard.html";
    }
  </script>
  <!-- ...existing code... -->
  <!-- ...existing code... -->
