  <!-- ✅ Preloader CSS -->
  <style id="cm-preloader-styles">
    #cm-preloader {
      position: fixed;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #0d2538;
      color: #fff;
      z-index: 99999;
      transition: opacity 0.6s ease;
      font-family: "Noto Sans", sans-serif;
    }

    .cm-preloader-inner {
      text-align: center;
    }

    .cm-loader-letters {
      display: inline-flex;
      gap: 6px;
      font-weight: 700;
      font-size: 32px;
      letter-spacing: 0.05em;
    }

    .cm-loader-letters span {
      display: inline-block;
      transform: translateY(0);
      animation: cm-float 1.6s ease-in-out infinite;
    }

    .cm-loader-letters span:nth-child(2) {
      animation-delay: 0.12s;
    }

    .cm-loader-letters span:nth-child(3) {
      animation-delay: 0.24s;
    }

    .cm-loader-letters span:nth-child(4) {
      animation-delay: 0.36s;
    }

    .cm-loader-letters span:nth-child(5) {
      animation-delay: 0.48s;
    }

    .cm-loader-letters span:nth-child(6) {
      animation-delay: 0.6s;
    }

    .cm-loader-letters span:nth-child(7) {
      animation-delay: 0.72s;
    }

    @keyframes cm-float {
      0% {
        transform: translateY(0);
        opacity: 1;
      }

      50% {
        transform: translateY(-10px);
        opacity: 0.95;
      }

      100% {
        transform: translateY(0);
        opacity: 1;
      }
    }

    .cm-preloader-hide {
      opacity: 0;
      pointer-events: none;
    }
  </style>

  <!-- ✅ Preloader JS -->
  <script id="cm-preloader-script">
    (function () {
      const preloader = document.getElementById("cm-preloader");

      function hidePreloader() {
        if (!preloader) return;
        preloader.classList.add("cm-preloader-hide");
        setTimeout(() => {
          preloader.style.display = "none";
        }, 600);
      }

      // Wait 2 seconds before hiding (smooth and consistent)
      function autoHide() {
        setTimeout(hidePreloader, 2000);
      }

      if (document.readyState === "complete") {
        autoHide();
      } else {
        window.addEventListener("load", autoHide, { once: true });
        // fallback just in case 'load' doesn't fire
        setTimeout(autoHide, 4000);
      }

      // Reusable functions
      window.showPreloader = function () {
        if (!preloader) return;
        preloader.style.display = "flex";
        requestAnimationFrame(() =>
          preloader.classList.remove("cm-preloader-hide")
        );
      };

      window.hidePreloader = hidePreloader;
    })();
  </script>
</body>

</html>